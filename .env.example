# ============================================================
# Resume2Job — Environment Variables
# HOW TO USE:
#   1. Copy this file: cp .env.example .env
#   2. Fill in REAL values in .env
#   3. NEVER commit .env to Git (it's in .gitignore)
# ============================================================

# ── Gemini API ─────────────────────────────────────────────
APP_API_KEY=your_gemini_api_key_here

# ── PostgreSQL ─────────────────────────────────────────────
POSTGRES_USER=resume2job
POSTGRES_PASSWORD=your_db_password_here
POSTGRES_DB=resume2job_db

# ── Redis ──────────────────────────────────────────────────
REDIS_PASSWORD=your_redis_password_here

# ── Flask ──────────────────────────────────────────────────
FLASK_ENV=production
SECRET_KEY=change_me_flask_secret_key

# ── AWS (used in CI/CD pipeline) ───────────────────────────
# Store these in GitHub Secrets, NOT here!
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-south-1
# ECR_REPOSITORY=resume2job
# EC2_HOST=your-ec2-public-ip

# ── Pinecone (Vector Database) ─────────────────────────────
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX_NAME=resume2job-index
